        "jsCode": "const config = $('Supabase - Config client1').item.json;\n\nconst delayMin = config.response_delay_min_minutes ?? 30;\nconst delayMax = config.response_delay_max_minutes ?? 45;\nconst activeStart = config.active_hours_start ?? 9;\nconst activeEnd = config.active_hours_end ?? 19;\nconst activeDays = config.active_days ?? [1, 2, 3, 4, 5];\nconst timezone = config.timezone ?? 'Europe/Paris';\n\nconst delayMinutes = Math.floor(Math.random() * (delayMax - delayMin + 1)) + delayMin;\nlet target = DateTime.now().setZone(timezone).plus({ minutes: delayMinutes });\n\nlet i = 0;\nwhile (i < 14) {\n  const h = target.hour;\n  const day = target.weekday;\n  if (activeDays.includes(day) && h >= activeStart && h < activeEnd) break;\n  if (!activeDays.includes(day) || h >= activeEnd) {\n    target = target.plus({ days: 1 }).set({ hour: activeStart, minute: 0, second: 0, millisecond: 0 });\n  } else {\n    target = target.set({ hour: activeStart, minute: 0, second: 0, millisecond: 0 });\n  }\n  i++;\n}\n\nreturn [{ json: { scheduled_send_at: target.toUTC().toISO() } }];\n"
      },
