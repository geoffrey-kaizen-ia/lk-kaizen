      "id": "81ee237d-0868-44bf-abcd-07444abbb8e7",
      "name": "Unipile - Historique IB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        864,
        640
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const items = $json.items || [];\nconst clientName = $('Supabase - Config client1').item.json.full_name || 'Client';\nconst chrono = items.filter(m => m.attendee_type === 'MEMBER' && !m.deleted);\nconst nombre_echanges = chrono.filter(m => m.is_sender === 1).length;\nconst historique = chrono.map(m => (m.is_sender === 1 ? clientName : 'Prospect') + ': ' + (m.text || '')).join('\\n');\nconst recus = chrono.filter(m => m.is_sender === 0);\nconst dernier_message = recus.length ? (recus[recus.length - 1].text || '') : ($('Webhook1').item.json.body.message || '');\nreturn { historique, dernier_message, nombre_echanges };"
      },
      "id": "e5ea9b83-1bca-4f48-8a76-ae89e2173776",
      "name": "Code - Discussion IB",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
        640
      ]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "id",
          "value": "claude-haiku-4-5-20251001"
        },
        "messages": {
          "values": [
            {
              "content": "=Conversation à analyser :\n\nDernier message du prospect :\n{{ $(\"Code - Discussion IB\").item.json.dernier_message }}\n\nHistorique de la conversation :\n{{ $(\"Code - Discussion IB\").item.json.historique }}\n\nDonne la note d'intérêt de ce prospect."
            }
          ]
        },
        "options": {
          "system": "Tu es un expert en analyse de conversations commerciales B2B.\nÉvalue le niveau d'intérêt du prospect (0 à 10) en analysant le ton et l'intention réelle de la conversation.\n\n## Critères\n- 9-10 : demande explicite de RDV, call, volonté claire d'avancer\n- 7-8 : questions concrètes sur l'offre, besoin précis exprimé\n- 4-6 : intérêt poli, temporise, va réfléchir\n- 1-3 : peu d'engagement, répond par politesse\n- 0 : refus clair, demande à stopper\n\nRéponds UNIQUEMENT en JSON strict, sans texte autour :\n{\"note\": <0-10>, \"justification\": \"<1-2 phrases>\"}",
          "maxTokens": 200,
          "temperature": 0
        }
      },
      "id": "f93afa7b-016f-4b4e-a1ad-f5bd0b35f06c",
      "name": "Claude - Scoring IB",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [
        1312,
        640
      ],
      "credentials": {
        "anthropicApi": {
          "id": "H0m8ZPv5z3Omd0Cw",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const r = $json;\nlet text = '';\nif (typeof r.text === 'string') text = r.text;\nelse if (Array.isArray(r.content) && r.content[0] && r.content[0].text) text = r.content[0].text;\nelse if (r.message && r.message.content) text = r.message.content;\nelse if (r.output) text = (typeof r.output === 'string' ? r.output : JSON.stringify(r.output));\n\nlet note = 0;\nlet justification = '';\ntry {\n  const clean = (text || '').trim().replace(/^```json?\\n?/, '').replace(/\\n?```$/, '');\n  const parsed = JSON.parse(clean);\n  note = typeof parsed.note === 'number' ? Math.round(parsed.note) : 0;\n  justification = typeof parsed.justification === 'string' ? parsed.justification : '';\n} catch(e) {\n  justification = 'Erreur parsing scoring';\n}\n\nreturn { note, justification };\n"
      },
