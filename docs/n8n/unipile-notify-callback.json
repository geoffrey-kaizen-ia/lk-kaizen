    {
      "parameters": {
        "jsCode": "const list = $('List WebHook').first().json.items || [];\n\n// tous les webhooks qui s'appellent LinkedIn_message_entrant\nconst mine = list.filter(w => w.name === \"LinkedIn_message_entrant\");\n\n// on garde celui qui a le plus de comptes (= le nouveau, liste complète)\nlet keep = null;\nfor (const w of mine) {\n  if (!keep || (w.account_ids || []).length > (keep.account_ids || []).length) {\n    keep = w;\n  }\n}\n\n// on renvoie les id de tous les AUTRES (à supprimer)\nreturn mine\n  .filter(w => keep && w.id !== keep.id)\n  .map(w => ({ json: { id: w.id } }));\n"
      },
