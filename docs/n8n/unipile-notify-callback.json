      "parameters": {
        "jsCode": "const EXCLU = \"\"; // mets ici l'account_id à exclure, ou laisse vide\n\nconst ids = items\n  .map(item => item.json.account_id)\n  .filter(id => id && id !== EXCLU);\n\nreturn [{\n  json: {\n    request_url: \"https://n8n.srv1213804.hstgr.cloud/webhook/LinkedIn_message_entrant\",\n    source: \"messaging\",\n    name: \"LinkedIn_message_entrant\",\n    events: [\"message_received\"],\n    account_ids: ids,\n    headers: [{ key: \"Content-Type\", value: \"application/json\" }]\n  }\n}];\n"
      },
